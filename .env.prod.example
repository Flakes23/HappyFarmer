# Dùng cho docker-compose.prod.yml trên VPS — copy thành `.env` (cùng thư mục compose file trên
# VPS, KHÔNG commit lên repo) rồi điền giá trị thật. INTERNAL_API_KEY phải là 1 chuỗi ngẫu nhiên
# tự đặt (không có ở đâu sẵn) — dùng chung để Marketplace Service gọi nội bộ sang Auth Service.

SQLSERVER_SA_PASSWORD= 
INTERNAL_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Domain frontend thật trên Vercel (vd. https://happyfarmer.vercel.app) — cập nhật sau khi deploy
# frontend xong ở bước sau, để trống tạm cũng được (CORS sẽ chặn cho tới khi điền đúng).
CORS_ALLOWED_ORIGINS=
