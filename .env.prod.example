# Dùng cho docker-compose.prod.yml trên VPS — copy thành `.env` (cùng thư mục compose file trên
# VPS, KHÔNG commit lên repo) rồi điền giá trị thật. INTERNAL_API_KEY phải là 1 chuỗi ngẫu nhiên
# tự đặt (không có ở đâu sẵn) — dùng chung để Marketplace/AI Advisory Service gọi nội bộ sang Auth
# Service. INTERNAL_INGEST_API_KEY cũng tự đặt ngẫu nhiên, RIÊNG với INTERNAL_API_KEY — chỉ dùng
# để RagIngestor (chạy thủ công từ máy local) xác thực khi nạp tài liệu RAG vào AI Advisory Service.

SQLSERVER_SA_PASSWORD=
INTERNAL_API_KEY=
INTERNAL_INGEST_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GEMINI_API_KEY=
OPENWEATHERMAP_API_KEY=

# Domain frontend thật trên Vercel (vd. https://happyfarmer.vercel.app) — cập nhật sau khi deploy
# frontend xong ở bước sau, để trống tạm cũng được (CORS sẽ chặn cho tới khi điền đúng).
CORS_ALLOWED_ORIGINS=
