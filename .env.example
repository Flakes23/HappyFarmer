# Copy file này thành .env (không commit .env thật) và điền giá trị thật.
# Lưu ý: chỉ SQLSERVER_SA_PASSWORD được docker-compose.yml (dev) đọc trực tiếp.
# Các biến còn lại là secret từng service cần khi chạy dev — set qua `dotnet user-secrets`
# ở đúng service (Auth/AiAdvisory/Marketplace...), không đọc từ file .env này.

# --- Docker Compose: SQL Server / Redis ---
SQLSERVER_SA_PASSWORD=Your_str0ng_Password!

# --- AI (AI Advisory Service, qua dotnet user-secrets) ---
GEMINI_API_KEY=
OPENWEATHERMAP_API_KEY=

# --- JWT (Auth Service, qua dotnet user-secrets) ---
JWT_ISSUER=happyfarmer-auth
JWT_AUDIENCE=happyfarmer-services

# --- SMTP (Notification Service — chưa triển khai, xem docs/architecture/services/notification-service.md) ---
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# --- CORS (API Gateway) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
