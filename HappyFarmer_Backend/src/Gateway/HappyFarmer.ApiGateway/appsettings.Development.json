{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "JwksUrl": "http://localhost:5242/.well-known/jwks.json",
    "Issuer": "happyfarmer-auth",
    "Audience": "happyfarmer-services"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5173"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**remainder}"
        }
      },
      "jwks-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/.well-known/jwks.json"
        }
      },
      "market-price-route": {
        "ClusterId": "market-price-cluster",
        "Match": {
          "Path": "/api/market-price/{**remainder}"
        }
      },
      "ai-advisory-route": {
        "ClusterId": "ai-advisory-cluster",
        "Match": {
          "Path": "/api/ai-advisory/{**remainder}"
        }
      },
      "marketplace-route": {
        "ClusterId": "marketplace-cluster",
        "Match": {
          "Path": "/api/marketplace/{**remainder}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notification/{**remainder}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5242"
          }
        }
      },
      "market-price-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5262"
          }
        }
      },
      "ai-advisory-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5224"
          }
        }
      },
      "marketplace-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5247"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5053"
          }
        }
      }
    }
  }
}
