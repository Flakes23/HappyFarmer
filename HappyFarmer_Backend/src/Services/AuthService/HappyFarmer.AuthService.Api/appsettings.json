{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "happyfarmer-auth",
    "Audience": "happyfarmer-services",
    "PrivateKeyPath": "keys/jwt-private.pem",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 14
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5173"
  }
}
